      "notes": [
        { "id": "n_d1", "title": "Homepage copy draft", "content": "Hero: \"Built for teams that move fast.\"\n\nSubhead: Simple tools, real results. Acme gives your team everything it needs — nothing it doesn't.\n\nCTA: Start free trial", "pinned": true, "createdAt": "2026-03-01T10:00:00Z", "updatedAt": "2026-03-05T14:30:00Z" },
        { "id": "n_d2", "title": "Client feedback - Round 2", "content": "- Loves the new nav layout\n- Wants bolder CTA buttons\n- Asked about dark mode support\n- Footer needs legal links added", "pinned": false, "createdAt": "2026-03-03T09:00:00Z", "updatedAt": "2026-03-04T16:00:00Z" },
        { "id": "n_d3", "title": "Color system notes", "content": "Primary: #0a84ff\nSecondary: #30d158\nNeutral: #8e8e93\n\nDark mode needs separate tokens. Don't just invert — use elevated surfaces with subtle opacity shifts.", "pinned": false, "createdAt": "2026-02-28T11:00:00Z", "updatedAt": "2026-03-02T09:15:00Z" },
        { "id": "n_d4", "title": "Accessibility checklist", "content": "- All interactive elements need 44px touch targets\n- Contrast ratio 4.5:1 minimum for body text\n- Skip nav link on every page\n- Alt text audit on all hero images\n- Test with VoiceOver before launch", "pinned": false, "createdAt": "2026-03-04T08:00:00Z", "updatedAt": "2026-03-05T10:00:00Z" }
